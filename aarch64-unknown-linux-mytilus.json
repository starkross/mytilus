{
  "llvm-target": "aarch64-unknown-linux-musl",
  "metadata": {
    "description": "mytilus target: ARMv8-A 64-bit Linux, little-endian, mytilus libc",
    "host_tools": false,
    "std": false,
    "tier": "custom"
  },
  "arch": "aarch64",
  "data-layout": "e-m:e-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128",
  "target-pointer-width": "64",
  "target-c-int-width": "32",
  "target-endian": "little",
  "max-atomic-width": 128,
  "pointer-width": "64",

  "os": "linux",
  "env": "musl",
  "vendor": "unknown",
  "target-family": ["unix"],

  "features": "+v8a,+neon,+fp-armv8,+outline-atomics",
  "abi": "",

  "linker": "rust-lld",
  "linker-flavor": "gnu-lld",
  "lld-flavor": "gnu",
  "linker-is-gnu": true,

  "panic-strategy": "abort",
  "relocation-model": "pic",
  "position-independent-executables": true,
  "static-position-independent-executables": true,

  "executables": true,
  "dynamic-linking": true,
  "has-rpath": true,
  "has-thread-local": true,
  "tls-model": "general-dynamic",

  "crt-objects-fallback": "false",
  "crt-static-respected": true,
  "crt-static-default": false,
  "crt-static-allows-dylibs": true,

  "supported-sanitizers": ["address", "leak", "thread", "hwaddress"],
  "supports-stack-protector": true,
  "stack-probes": { "kind": "inline" },

  "frame-pointer": "non-leaf",
  "eh-frame-header": false,
  "default-codegen-units": 1
}
